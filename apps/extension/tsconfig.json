{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "jsx": "react-jsx",
    "paths": {
      "@src": ["./src"],
      "@src/*": ["./src/*"]
    }
  },
  "include": [
    ".wxt/**/*.d.ts",
    "src/**/*",
    "entrypoints/**/*",
    "tests/**/*",
    "vitest.config.ts",
    "playwright.config.ts"
  ]
}
