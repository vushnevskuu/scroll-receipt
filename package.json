{
  "name": "scroll-receipt",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @scroll-receipt/extension dev",
    "build": "pnpm --filter @scroll-receipt/shared build && pnpm --filter @scroll-receipt/extension build",
    "zip": "pnpm --filter @scroll-receipt/extension zip",
    "release:extension": "pnpm build && pnpm zip && cp apps/extension/.output/scroll-receiptextension-2.0.0-chrome.zip docs/scroll-receipt-2.0.0-chrome.zip",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @scroll-receipt/extension test:e2e",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "typescript": "^5.9.3"
  }
}
